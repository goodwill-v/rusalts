# Переменные страницы /talk (страница связи со сторонними приложениями)

# Ключ доступа (вводится пользователем при входе на /talk).
# Клиент будет хранить ключ в localStorage браузера.
TALK_KEY=replace-me-with-a-long-secret

# Токен доступа для СТОРОННЕГО приложения, которое отправляет сообщения/файлы ВНУТРЬ /talk.
# Если не задан, сервер будет ожидать TALK_KEY.
TALK_APP_TOKEN=replace-me-with-an-app-token

# Адрес бота/приложения, к которому АЛТ будет проксировать сообщения из /talk.
# Пример (если бот запущен как docker-сервис "bot" в той же сети):
# TALK_RELAY_URL=http://bot:9010/talk
# Пример (если используется SSH reverse tunnel на хосте и AЛТ в Docker):
# TALK_RELAY_URL=http://host.docker.internal:19010/talk
TALK_RELAY_URL=http://bot:9010/talk

# Необязательный ключ для защиты бота. Если задан — АЛТ будет добавлять заголовок:
# X-App-Key: <TALK_RELAY_APP_KEY>
TALK_RELAY_APP_KEY=
