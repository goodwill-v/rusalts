# Переменные страницы /talk (страница связи со сторонними приложениями)

# Ключ доступа (вводится пользователем при входе на /talk).
# Клиент будет хранить ключ в localStorage браузера.
TALK_KEY=replace-me-with-a-long-secret

# Токен доступа для СТОРОННЕГО приложения, которое отправляет сообщения/файлы ВНУТРЬ /talk.
# Если не задан, сервер будет ожидать TALK_KEY.
TALK_APP_TOKEN=replace-me-with-an-app-token

# Ровно 3 разрешённых адреса для связи (allowlist).
# Это конечные HTTP(S) адреса сторонних приложений (в т.ч. локальные на этом сервере).
# Формат: через запятую, без пробелов.
# Пример:
# 1) приложение на этом компьютере
# 2) приложение в другой директории этого же сервера (через отдельный порт/виртуальный хост)
# 3) приложение на другом сервере
TALK_ALLOWED_URLS=http://127.0.0.1:9010/talk,http://127.0.0.1:9020/talk,https://example.org/talk
