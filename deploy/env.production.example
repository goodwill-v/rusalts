# Скопируйте на сервер как /opt/alt/.env (значение FRAME_ANCESTORS в двойных кавычках — для dotenv)
PUBLIC_BASE_URL=https://rusalts.ru
CORS_ORIGINS=https://rusalts.ru,https://www.rusalts.ru,https://vk.com,https://vk.ru,https://m.vk.com
FRAME_ANCESTORS="'self' https://rusalts.ru https://www.rusalts.ru https://vk.com https://*.vk.com https://vk.ru https://*.vk.ru https://m.vk.com"
MAX_UPLOAD_BYTES=5242880
DEBUG=false

# RouterAI (OpenAI-compatible)
ROUTERAI_BASE_URL=https://routerai.ru/api/v1
ROUTERAI_API_KEY=REPLACE_ME

# Agent model routing (main → heavy)
BACKEND_MODEL_MAIN=google/gemini-2.5-flash
BACKEND_MODEL_HEAVY=openai/gpt-5.4

PARSER_MODEL_MAIN=deepseek/deepseek-v3.2
PARSER_MODEL_HEAVY=anthropic/claude-sonnet-4.6

CONTENT_MODEL_MAIN=qwen/qwen3.6-plus
CONTENT_MODEL_HEAVY=anthropic/claude-sonnet-4.6

# Content approvals mode (prod automation)
CONTENT_APPROVAL_MODE=local_autoapprove

# Queue / inter-service messaging (Redis Streams)
QUEUE_REDIS_URL=redis://redis:6379/0
QUEUE_STREAM_PARSER_JOBS=alt:parser:jobs
QUEUE_STREAM_CONTENT_JOBS=alt:content:jobs
QUEUE_GROUP_PARSER=parser
QUEUE_GROUP_CONTENT=content
